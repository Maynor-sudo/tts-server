<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>TTS App</title>

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
body {
    background: linear-gradient(135deg, #1e1e2f, #2a2a40);
    color: white;
    font-family: 'Segoe UI', sans-serif;
}

.card {
    border-radius: 15px;
    background: #2f2f4a;
    box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}

textarea {
    border-radius: 10px;
    resize: none;
}

.btn-primary {
    background: #6c5ce7;
    border: none;
}

.btn-primary:hover {
    background: #5a4bd1;
}

select {
    border-radius: 10px;
}

.counter {
    font-size: 12px;
    color: #aaa;
}

audio {
    width: 100%;
    margin-top: 10px;
}
</style>

</head>

<body>

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 w-100" style="max-width: 500px;">

        <h3 class="text-center mb-3">
            <i class="fas fa-microphone"></i> Texto a Voz
        </h3>

        <form method="POST" action="/tts">

            <!-- TEXTO -->
            <textarea name="text" id="text" maxlength="500" class="form-control mb-2"
                placeholder="Escribe tu texto aquí..."></textarea>

            <div class="counter text-end mb-3" id="counter">0 / 500</div>

            <!-- IDIOMA -->
            <label><i class="fas fa-language"></i> Idioma destino</label>
            <select name="language" class="form-select mb-3">
                <option value="auto">Sin traducir</option>
                <option value="inglés">Inglés</option>
                <option value="francés">Francés</option>
                <option value="alemán">Alemán</option>
            </select>

            <!-- VOZ -->
            <label><i class="fas fa-user"></i> Tipo de voz</label>
            <select name="voice" class="form-select mb-3">
                <option value="alloy">Neutra</option>
                <option value="nova">Femenina</option>
                <option value="verse">Masculina</option>
                <option value="onyx">Masculina profunda</option>
                <option value="shimmer">Femenina suave</option>
            </select>

            <!-- VELOCIDAD (visual) -->
            <label><i class="fas fa-tachometer-alt"></i> Velocidad</label>
            <select class="form-select mb-4">
                <option>Normal</option>
                <option>Lento</option>
                <option>Rápido</option>
            </select>

            <!-- BOTÓN -->
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-play"></i> Convertir a voz
            </button>

        </form>

        {% if audio_file %}
        <div class="mt-4">
            <h5><i class="fas fa-headphones"></i> Resultado</h5>

            <audio controls>
                <source src="/static/audio/{{ audio_file }}" type="audio/mpeg">
            </audio>

            <a href="/static/audio/{{ audio_file }}" download class="btn btn-success w-100 mt-2">
                <i class="fas fa-download"></i> Descargar audio
            </a>
        </div>
        {% endif %}

    </div>
</div>

<script>
const textarea = document.getElementById("text");
const counter = document.getElementById("counter");

textarea.addEventListener("input", () => {
    counter.textContent = textarea.value.length + " / 500";
});
</script>

</body>
</html>
